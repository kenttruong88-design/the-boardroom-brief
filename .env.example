# ─────────────────────────────────────────────────────────────────────────────
# The Alignment Times — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Sanity CMS ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=sk...
SANITY_WEBHOOK_SECRET=     # openssl rand -hex 32

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://alignmenttimes.com
NEXT_PUBLIC_CONTACT_EMAIL=hello@alignmenttimes.com

# ── Contact form ──────────────────────────────────────────────────────────────
EDITOR_EMAIL=editor@alignmenttimes.com   # receives contact form notifications
IP_HASH_SALT=                            # openssl rand -hex 32

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=price_...

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Market data ───────────────────────────────────────────────────────────────
POLYGON_API_KEY=...
FMP_API_KEY=...

# ── Search (Algolia) ─────────────────────────────────────────────────────────
# Create a free index at algolia.com → Applications → Indices
# Search-only key: safe to expose publicly (NEXT_PUBLIC_)
# Admin key: server-only, never expose to browser
NEXT_PUBLIC_ALGOLIA_APP_ID=           # Settings → API Keys → Application ID
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=       # Settings → API Keys → Search-Only API Key
ALGOLIA_ADMIN_KEY=                    # Settings → API Keys → Admin API Key
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=alignment_times_articles

# ── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=alignmenttimes.com
NEXT_PUBLIC_PLAUSIBLE_HOST=https://plausible.io

# ── Ads ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-...

# ── Social / Buffer ───────────────────────────────────────────────────────────
BUFFER_ACCESS_TOKEN=...
BUFFER_LINKEDIN_PROFILE_ID=...
BUFFER_TWITTER_PROFILE_ID=...
SOCIAL_TIMEZONE=America/New_York

# ── Notifications ─────────────────────────────────────────────────────────────
SLACK_EDITORIAL_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Security ──────────────────────────────────────────────────────────────────
CRON_SECRET=          # openssl rand -hex 32
NEWSLETTER_SECRET=    # openssl rand -hex 32
IP_HASH_SALT=         # openssl rand -hex 32

# ── Sentry ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=the-boardroom-brief
SENTRY_AUTH_TOKEN=sntrys_...
